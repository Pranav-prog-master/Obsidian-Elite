# EduMentor AI - Environment Variables Template
# Copy this file to .env and fill in your real values
# NEVER commit the actual .env file to GitHub

# -----------------------------------------------
# OPENROUTER AI - Free credits on signup
# Get from: https://openrouter.ai → Keys → Create Key
# No credit card needed for free tier models
# -----------------------------------------------
OPENROUTER_API_KEY=sk-or-your-key-here
AI_MODEL_PRIMARY=google/gemma-2-9b-it:free
AI_MODEL_BACKUP=mistralai/mistral-7b-instruct:free
AI_PROVIDER=openrouter
APP_SITE_URL=http://localhost:5173
APP_TITLE=EduMentor AI

# -----------------------------------------------
# SUPABASE DATABASE
# Get from: https://supabase.com → Project → Settings → API
# -----------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJyour-anon-key-here
SUPABASE_SERVICE_KEY=eyJyour-service-role-key-here

# -----------------------------------------------
# JWT AUTHENTICATION
# Generate your own random string for SECRET_KEY
# -----------------------------------------------
SECRET_KEY=your-random-secret-key-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# -----------------------------------------------
# SERVER CONFIG
# -----------------------------------------------
BACKEND_PORT=8000
ENVIRONMENT=development

# -----------------------------------------------
# FRONTEND
# -----------------------------------------------
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=EduMentor AI
VITE_APP_VERSION=1.0.0
